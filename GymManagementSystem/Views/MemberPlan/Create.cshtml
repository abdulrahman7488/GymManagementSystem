@model GymManagementSystem.BLL.ViewModels.MemberPlanViewModels.CreateMemberPlanViewModel
@{ ViewData["Title"] = "Assign Plan"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white text-center py-4">
                    <i class="bi bi-person-check display-6 mb-2 d-block"></i>
                    <h4 class="mb-0">Assign Plan to Member</h4>
                </div>
                <div class="card-body p-4">
                    <div asp-validation-summary="All" class="alert alert-danger"
                         style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="MemberId" class="form-label fw-semibold">Member</label>
                            <select asp-for="MemberId" asp-items="Model.Members" class="form-select">
                                <option value="">-- Select Member --</option>
                            </select>
                            <span asp-validation-for="MemberId" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PlanId" class="form-label fw-semibold">Plan</label>
                            <select asp-for="PlanId" asp-items="Model.Plans" class="form-select">
                                <option value="">-- Select Plan --</option>
                            </select>
                            <span asp-validation-for="PlanId" class="text-danger small"></span>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary flex-fill">
                                <i class="bi bi-check-circle me-1"></i>Assign
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                                <i class="bi bi-arrow-left me-1"></i>Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
