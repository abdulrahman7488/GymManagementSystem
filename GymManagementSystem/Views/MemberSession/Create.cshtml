@model GymManagementSystem.BLL.ViewModels.MemberSessionViewModels.CreateBookingViewModel
@{ ViewData["Title"] = "Book Session"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white text-center py-4">
                    <i class="bi bi-calendar-check display-6 mb-2 d-block"></i>
                    <h4 class="mb-0">Book a Session</h4>
                </div>
                <div class="card-body p-4">
                    <div class="bg-light rounded p-3 mb-4">
                        <h6 class="text-primary mb-2"><i class="bi bi-info-circle me-1"></i>Session Details</h6>
                        <p class="mb-1"><strong>Description:</strong> @Model.SessionDescription</p>
                        <p class="mb-1"><strong>Date:</strong> @Model.SessionStart.ToString("dd MMM yyyy")</p>
                        <p class="mb-1"><strong>Time:</strong> @Model.SessionStart.ToString("hh:mm tt") – @Model.SessionEnd.ToString("hh:mm tt")</p>
                        <p class="mb-0"><strong>Available Seats:</strong>
                            <span class="badge @(Model.AvailableSeats > 0 ? "bg-success" : "bg-danger")">@Model.AvailableSeats</span>
                        </p>
                    </div>
                    <div asp-validation-summary="All" class="alert alert-danger"
                         style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="sessionId" value="@Model.SessionId" />
                        <div class="mb-3">
                            <label asp-for="MemberId" class="form-label fw-semibold">Select Member</label>
                            <select asp-for="MemberId" asp-items="Model.Members" class="form-select">
                                <option value="">-- Select Member --</option>
                            </select>
                            <span asp-validation-for="MemberId" class="text-danger small"></span>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary flex-fill">
                                <i class="bi bi-check-circle me-1"></i>Confirm Booking
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                                <i class="bi bi-arrow-left me-1"></i>Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
