@model GymManagementSystem.BLL.ViewModels.MemberSessionViewModels.SessionMembersViewModel
@{
    ViewData["Title"] = $"{Model.SessionType} Session – Members";
    bool isOngoing = Model.SessionType == "Ongoing";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">
                <span class="badge @(isOngoing ? "bg-success" : "bg-primary") me-2"
                      style="font-size:.55em;vertical-align:middle;">@Model.SessionType.ToUpper()</span>
                Session Members
            </h2>
            <p class="text-muted mb-0">@Model.SessionDescription &nbsp;|&nbsp; @Model.DateDisplay &nbsp;|&nbsp; @Model.TimeRange</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>

    @if (!Model.Members.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-people display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No Members Booked</h4>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th><th>Member</th><th>Phone</th><th>Booking Date</th>
                        @if (isOngoing) { <th class="text-center">Attended</th><th class="text-center">Mark</th> }
                        else { <th class="text-center">Cancel</th> }
                    </tr>
                </thead>
                <tbody>
                    @{ int row = 1; }
                    @foreach (var m in Model.Members)
                    {
                        <tr>
                            <td>@row</td>
                            <td>@m.MemberName</td>
                            <td>@m.MemberPhone</td>
                            <td>@m.BookingDate</td>
                            @if (isOngoing)
                            {
                                <td class="text-center">
                                    <span class="badge @(m.IsAttended ? "bg-success" : "bg-secondary")">
                                        @(m.IsAttended ? "Yes" : "No")
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (!m.IsAttended)
                                    {
                                        <form asp-action="MarkAttendance" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="memberId"  value="@m.MemberId" />
                                            <input type="hidden" name="sessionId" value="@m.SessionId" />
                                            <button type="submit" class="btn btn-success btn-sm">
                                                <i class="bi bi-check2-circle me-1"></i>Mark
                                            </button>
                                        </form>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                            }
                            else
                            {
                                <td class="text-center">
                                    <form asp-action="Cancel" method="post"
                                          onsubmit="return confirm('Cancel this booking?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="memberId"  value="@m.MemberId" />
                                        <input type="hidden" name="sessionId" value="@m.SessionId" />
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="bi bi-x-circle me-1"></i>Cancel
                                        </button>
                                    </form>
                                </td>
                            }
                        </tr>
                        row++;
                    }
                </tbody>
            </table>
        </div>
    }
</div>
