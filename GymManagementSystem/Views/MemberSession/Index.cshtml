@model GymManagementSystem.BLL.ViewModels.MemberSessionViewModels.SessionsIndexViewModel
@{ ViewData["Title"] = "Sessions Schedule"; }

<div class="container mt-4">

    @* ONGOING *@
    <div class="d-flex align-items-center mb-3">
        <h2 class="mb-0">
            <span class="badge bg-success me-2" style="font-size:.55em;vertical-align:middle;">LIVE</span>
            Ongoing Sessions
        </h2>
    </div>

    @if (!Model.OngoingSessions.Any())
    {
        <p class="text-muted mb-5">No ongoing sessions right now.</p>
    }
    else
    {
        <div class="row g-4 mb-5">
            @foreach (var s in Model.OngoingSessions)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-success text-white d-flex justify-content-between">
                            <span class="fw-bold">@s.CategoryName</span>
                            <span class="badge bg-light text-dark">@s.AvailableSeats left</span>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <p class="text-muted mb-2">@s.Description</p>
                            <p class="mb-1"><i class="bi bi-person-fill me-2 text-success"></i><strong>Trainer:</strong> @s.TrainerName</p>
                            <p class="mb-1"><i class="bi bi-clock me-2 text-success"></i><strong>Time:</strong> @s.TimeRangeDisplay</p>
                            <p class="mb-3"><i class="bi bi-people me-2 text-success"></i><strong>Booked:</strong> @s.BookedCount / @s.Capacity</p>
                            <div class="mt-auto">
                                <a asp-action="GetMembersForOngoingSessions" asp-route-sessionId="@s.SessionId"
                                   class="btn btn-outline-success btn-sm w-100">
                                    <i class="bi bi-people me-1"></i>View Members
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @* UPCOMING *@
    <div class="d-flex align-items-center mb-3">
        <h2 class="mb-0">
            <span class="badge bg-primary me-2" style="font-size:.55em;vertical-align:middle;">SOON</span>
            Upcoming Sessions
        </h2>
    </div>

    @if (!Model.UpcomingSessions.Any())
    {
        <p class="text-muted">No upcoming sessions.</p>
    }
    else
    {
        <div class="row g-4">
            @foreach (var s in Model.UpcomingSessions)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-primary text-white d-flex justify-content-between">
                            <span class="fw-bold">@s.CategoryName</span>
                            <span class="badge bg-light text-dark">@s.AvailableSeats left</span>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <p class="text-muted mb-2">@s.Description</p>
                            <p class="mb-1"><i class="bi bi-person-fill me-2 text-primary"></i><strong>Trainer:</strong> @s.TrainerName</p>
                            <p class="mb-1"><i class="bi bi-calendar3 me-2 text-primary"></i><strong>Date:</strong> @s.DateDisplay</p>
                            <p class="mb-1"><i class="bi bi-clock me-2 text-primary"></i><strong>Time:</strong> @s.TimeRangeDisplay</p>
                            <p class="mb-3"><i class="bi bi-people me-2 text-primary"></i><strong>Booked:</strong> @s.BookedCount / @s.Capacity</p>
                            <div class="mt-auto d-grid gap-2">
                                @if (s.AvailableSeats > 0)
                                {
                                    <a asp-action="Create" asp-route-sessionId="@s.SessionId"
                                       class="btn btn-primary btn-sm">
                                        <i class="bi bi-plus-circle me-1"></i>Book
                                    </a>
                                }
                                else { <button class="btn btn-secondary btn-sm" disabled>Full</button> }
                                <a asp-action="GetMembersForUpcomingSession" asp-route-sessionId="@s.SessionId"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-people me-1"></i>View Members
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
