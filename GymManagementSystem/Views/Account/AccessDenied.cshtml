@{ ViewData["Title"] = "Access Denied"; Layout = "_Layout"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <i class="bi bi-shield-exclamation display-1 text-danger mb-4 d-block"></i>
            <h2 class="text-danger">Access Denied</h2>
            <p class="text-muted fs-5">You don't have permission to view this page.</p>
            <a asp-action="Index" asp-controller="Home" class="btn btn-primary mt-3">
                <i class="bi bi-house me-2"></i>Go Home
            </a>
            <a asp-action="Login" asp-controller="Account" class="btn btn-outline-secondary mt-3 ms-2">
                <i class="bi bi-box-arrow-in-right me-2"></i>Login with another account
            </a>
        </div>
    </div>
</div>
